# MyBotIA app — variables d'environnement
# Copier en .env.local et renseigner les valeurs réelles. Ne JAMAIS commiter .env.local.

# ============================================================
# Auth service (api-mybotia)
# ============================================================
AUTH_URL=http://127.0.0.1:3020
JWT_SECRET=__set_in_local__   # doit matcher l'auth-service. Jamais commit.

# ============================================================
# Dolibarr — un endpoint + clé API par tenant
# Doctrine 5G : un cockpit par hostname → un Dolibarr par tenant.
# Chaque clé reste exclusivement serveur (jamais NEXT_PUBLIC_*).
# ============================================================

# Tenant par défaut (dev local, fallback)
DOLIBARR_URL=https://crm-mybotia.mybotia.com/api/index.php
DOLIBARR_API_KEY=__set_in_local__

# tenant=mybotia (cockpit Gilles)
DOLIBARR_URL_MYBOTIA=https://crm-mybotia.mybotia.com/api/index.php
DOLIBARR_KEY_MYBOTIA=__set_in_local__

# tenant=vlmedical (cockpit Max)
DOLIBARR_URL_VLMEDICAL=https://crm-vlmedical.mybotia.com/api/index.php
DOLIBARR_KEY_VLMEDICAL=__set_in_local__

# tenant=igh (cockpit Lucy — note : Lucy a son MVP IGH dédié, ce CRM = suivi commercial)
DOLIBARR_URL_IGH=https://crm-igh.mybotia.com/api/index.php
DOLIBARR_KEY_IGH=__set_in_local__

# tenant=cmb_lux (cockpit Raphaël)
DOLIBARR_URL_CMBLUX=https://crm-cmblux.mybotia.com/api/index.php
DOLIBARR_KEY_CMBLUX=__set_in_local__

# ============================================================
# Bridge Claude (poc-bridge)
# ============================================================
CLAUDE_BRIDGE_URL=http://127.0.0.1:9300
CLAUDE_BRIDGE_TOKEN=__set_in_local__

# ============================================================
# API MyBotIA (api-mybotia)
# ============================================================
MYBOTIA_API_URL=http://127.0.0.1:3015
MYBOTIA_API_TOKEN=__set_in_local__

# ============================================================
# SSO Dolibarr (ticket short-lived)
# ============================================================
MYBOTIA_SSO_SECRET=__set_in_local__

# ============================================================
# Public flags (NEXT_PUBLIC_* est exposé au navigateur)
# ============================================================
NEXT_PUBLIC_VOICE_ENABLED=false
